# 이 파일을 .env.local로 복사한 뒤 값을 채워 넣으세요.
# .env.local은 gitignore되어 커밋되지 않습니다.
#
# ⚠️ Vercel 배포 시: 이 파일은 자동으로 올라가지 않습니다.
#    아래 모든 변수를 Vercel 프로젝트 Settings > Environment Variables에
#    직접 등록해야 합니다 (Production/Preview 환경 모두).

# --- Supabase (프로젝트 설정 > API에서 확인) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service role 키 — 크론(캘린더 동기화) 전용. 절대 클라이언트에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# --- 사이트 ---
# 배포 URL (iCal export 피드 주소 생성에 사용).
# 도메인 연결 전: https://<프로젝트명>.vercel.app / 연결 후: https://stayaphae.com
# 도메인 변경 시 에어비앤비 등에 등록한 iCal export URL도 재등록할 것.
NEXT_PUBLIC_SITE_URL=

# --- 예약 알림 (텔레그램 / 구글챗 중 사용하는 것만 설정) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GOOGLE_CHAT_WEBHOOK_URL=

# --- 크론 (외부 캘린더 동기화 엔드포인트 보호용 비밀값) ---
# Vercel에서는 이 이름(CRON_SECRET) 그대로 등록하면 Vercel Cron이
# 호출 시 Authorization: Bearer <값> 헤더를 자동으로 붙여준다.
# 값 생성 예: openssl rand -hex 32
CRON_SECRET=

# --- (4순위 예정) 게스트 확인 이메일 — Resend 가입 후 설정 ---
# RESEND_API_KEY=
